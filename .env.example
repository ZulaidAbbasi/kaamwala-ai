# =============================================================================
# KaamWala AI — Environment Variables
# =============================================================================
# SECURITY: Copy this file to .env and fill in your real values.
# NEVER commit .env to Git. Only .env.example should be in the repo.
# =============================================================================

# Firebase Configuration (non-secret client config — safe for mobile app)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=kaamwala-ai
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Backend API URL (Cloud Functions base URL)
EXPO_PUBLIC_API_BASE_URL=https://us-central1-kaamwala-ai.cloudfunctions.net/api

# =============================================================================
# SECRET KEYS — BACKEND ONLY (never in mobile app)
# Set these via: firebase functions:config:set
#   firebase functions:config:set gemini.api_key="YOUR_KEY"
#   firebase functions:config:set maps.api_key="YOUR_KEY"
# =============================================================================
