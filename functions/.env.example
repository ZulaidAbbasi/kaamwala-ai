# =============================================================================
# KaamWala AI — Cloud Functions Environment Variables
# =============================================================================
# SECURITY: Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# =============================================================================

# Google Gemini API Key (SECRET — from aistudio.google.com/apikey)
GEMINI_API_KEY=

# Google Maps/Places API Key (SECRET — from GCP Console → Credentials)
GOOGLE_MAPS_API_KEY=

# Project ID (not secret, but required for configuration)
KAAMWALA_PROJECT_ID=kaamwala-ai
